{
	"compilerOptions": {
		"baseUrl": ".",
		"outDir": "dist",
		"paths": {
			"main": ["src/main"],
			"domain": ["src/domain"],
			"domain/*": ["src/domain/*"],
			"ui": ["src/ui"],
			"ui/*": ["src/ui/*"],
			"types": ["src/types"],
			"types/*": ["src/types/*"],
			"utils": ["src/utils"],
			"utils/*": ["src/utils/*"],
			"shared/*": ["src/shared/*"]
		},
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"],
		"resolveJsonModule": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["__tests__/**/*", "__mocks__/**/*", "node_modules"]
}
